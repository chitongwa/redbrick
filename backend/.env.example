# ── Server ──
PORT=3000
USE_MOCKS=true

# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/redbrick

# ── Auth ──
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
OTP_EXPIRY_SECONDS=300

# ── Twilio (real SMS) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── ZESCO API (real integration) ──
ZESCO_API_URL=
ZESCO_API_KEY=

# ── Mobile Money (real integration) ──
MTN_MOMO_API_URL=
MTN_MOMO_API_KEY=
AIRTEL_MONEY_API_URL=
AIRTEL_MONEY_API_KEY=
