# ═══════════════════════════════════════════════════════════════════════════════
# RedBrick — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file:   cp .env.example .env
# Then fill in values before running:   docker compose up --build

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=redbrick
POSTGRES_PASSWORD=redbrick
POSTGRES_DB=redbrick

# Constructed automatically inside docker-compose.yml:
#   DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# If running outside Docker, set explicitly:
DATABASE_URL=postgresql://redbrick:redbrick@localhost:5432/redbrick

# ── Backend Server ────────────────────────────────────────────────────────────
PORT=3000
USE_MOCKS=true
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
OTP_EXPIRY_SECONDS=300

# ── Scoring Engine ────────────────────────────────────────────────────────────
SCORING_ENGINE_URL=http://scoring:5000

# ── Twilio (SMS / OTP delivery) ──────────────────────────────────────────────
# Sign up at https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── ZESCO API (electricity provider) ─────────────────────────────────────────
# Provided by ZESCO when you register as a third-party vendor
ZESCO_API_URL=https://api.zesco.co.zm/v1
ZESCO_API_KEY=your_zesco_api_key

# ── MTN Mobile Money ─────────────────────────────────────────────────────────
# Register at https://momodeveloper.mtn.com
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_API_KEY=your_mtn_momo_api_key

# ── Airtel Money ──────────────────────────────────────────────────────────────
# Register at https://developers.airtel.africa
AIRTEL_MONEY_API_URL=https://openapi.airtel.africa
AIRTEL_MONEY_API_KEY=your_airtel_money_api_key
